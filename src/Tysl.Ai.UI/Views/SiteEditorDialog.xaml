<Window x:Class="Tysl.Ai.UI.Views.SiteEditorDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Style="{StaticResource ShellWindowStyle}"
        Title="{Binding Title}"
        Width="800"
        Height="820"
        MinWidth="700"
        MinHeight="720"
        ResizeMode="CanResize">
    <Grid Margin="22">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel>
            <TextBlock FontSize="24" FontWeight="SemiBold" Text="{Binding Title}" />
            <TextBlock Margin="0,6,0,0"
                       Style="{StaticResource CaptionTextStyle}"
                       Text="本地点位维护信息用于坐标治理与后续派单闭环。设备编码和设备名称只读，保存后写入本地。" />
        </StackPanel>

        <Border Grid.Row="1" Margin="0,18,0,18" Style="{StaticResource PanelCardStyle}">
            <ScrollViewer VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled"
                          CanContentScroll="True">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="20" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0">
                            <TextBlock Style="{StaticResource DialogFieldLabelStyle}" Text="设备编码" />
                            <TextBox Style="{StaticResource DialogTextBoxStyle}"
                                     IsReadOnly="True"
                                     Text="{Binding DeviceCode, Mode=OneWay}" />

                            <TextBlock Style="{StaticResource DialogFieldLabelStyle}" Text="设备名称" />
                            <TextBox Style="{StaticResource DialogTextBoxStyle}"
                                     IsReadOnly="True"
                                     Text="{Binding DeviceName, Mode=OneWay}" />

                            <TextBlock Style="{StaticResource DialogFieldLabelStyle}" Text="别名" />
                            <TextBox Style="{StaticResource DialogTextBoxStyle}" Text="{Binding Alias, UpdateSourceTrigger=PropertyChanged}" />

                            <TextBlock Style="{StaticResource DialogFieldLabelStyle}" Text="维护单位" />
                            <TextBox Style="{StaticResource DialogTextBoxStyle}" Text="{Binding MaintenanceUnit, UpdateSourceTrigger=PropertyChanged}" />

                            <TextBlock Style="{StaticResource DialogFieldLabelStyle}" Text="维护人员" />
                            <TextBox Style="{StaticResource DialogTextBoxStyle}" Text="{Binding MaintainerName, UpdateSourceTrigger=PropertyChanged}" />

                            <TextBlock Style="{StaticResource DialogFieldLabelStyle}" Text="联系电话" />
                            <TextBox Style="{StaticResource DialogTextBoxStyle}" Text="{Binding MaintainerPhone, UpdateSourceTrigger=PropertyChanged}" />

                            <TextBlock Style="{StaticResource DialogFieldLabelStyle}" Text="所属片区" />
                            <TextBox Style="{StaticResource DialogTextBoxStyle}" Text="{Binding AreaName, UpdateSourceTrigger=PropertyChanged}" />

                            <TextBlock Style="{StaticResource DialogFieldLabelStyle}" Text="地址文本" />
                            <TextBox Style="{StaticResource DialogTextBoxStyle}" Text="{Binding AddressText, UpdateSourceTrigger=PropertyChanged}" />

                            <TextBlock Style="{StaticResource DialogFieldLabelStyle}" Text="默认派单说明 / 现场备注" />
                            <TextBox Style="{StaticResource DialogMultilineTextBoxStyle}"
                                     MinHeight="92"
                                     TextWrapping="Wrap"
                                     Text="{Binding DefaultDispatchRemark, UpdateSourceTrigger=PropertyChanged}" />
                        </StackPanel>

                        <StackPanel Grid.Column="2">
                            <TextBlock Style="{StaticResource DialogFieldLabelStyle}" Text="产品接入号" />
                            <TextBox Style="{StaticResource DialogTextBoxStyle}" Text="{Binding ProductAccessNumber, UpdateSourceTrigger=PropertyChanged}" />

                            <CheckBox Style="{StaticResource DialogCheckBoxStyle}"
                                      IsChecked="{Binding IsMonitored}"
                                      Content="纳入静默巡检" />

                            <CheckBox Style="{StaticResource DialogCheckBoxStyle}"
                                      IsChecked="{Binding IsAutoDispatchEnabled}"
                                      Content="启用自动派单" />

                            <CheckBox Style="{StaticResource DialogCheckBoxStyle}"
                                      IsChecked="{Binding AllowRecoveryAutoArchive}"
                                      Content="允许恢复自动归档" />

                            <TextBlock Style="{StaticResource DialogFieldLabelStyle}" Text="恢复确认方式" />
                            <ComboBox Style="{StaticResource DialogComboBoxStyle}"
                                      DisplayMemberPath="Label"
                                      ItemsSource="{Binding RecoveryConfirmationModeOptions}"
                                      SelectedValue="{Binding SelectedRecoveryConfirmationMode}"
                                      SelectedValuePath="Value" />

                            <TextBlock Style="{StaticResource DialogFieldLabelStyle}" Text="手工经度" />
                            <TextBox Style="{StaticResource DialogTextBoxStyle}" Text="{Binding LongitudeText, UpdateSourceTrigger=PropertyChanged}" />

                            <TextBlock Style="{StaticResource DialogFieldLabelStyle}" Text="手工纬度" />
                            <TextBox Style="{StaticResource DialogTextBoxStyle}" Text="{Binding LatitudeText, UpdateSourceTrigger=PropertyChanged}" />

                            <Button Margin="0,14,0,0"
                                    HorizontalAlignment="Left"
                                    MinWidth="132"
                                    Command="{Binding BeginCoordinatePickCommand}"
                                    Style="{StaticResource FlatActionButtonStyle}"
                                    Content="点选手工坐标" />
                            <TextBlock Margin="0,10,0,0"
                                       MinHeight="40"
                                       Style="{StaticResource CaptionTextStyle}"
                                       TextWrapping="Wrap"
                                       Text="{Binding CoordinatePickSummary}" />
                        </StackPanel>
                    </Grid>

                    <Grid Grid.Row="1" Margin="0,18,0,0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <TextBlock Style="{StaticResource DialogFieldLabelStyle}" Text="业务备注" />
                        <TextBox Grid.Row="1"
                                 Style="{StaticResource DialogMultilineTextBoxStyle}"
                                 MinHeight="160"
                                 VerticalAlignment="Top"
                                 Text="{Binding Remark, UpdateSourceTrigger=PropertyChanged}" />
                    </Grid>
                </Grid>
            </ScrollViewer>
        </Border>

        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <Button Grid.Column="1"
                    MinWidth="140"
                    Command="{Binding SaveCommand}"
                    Style="{StaticResource AccentActionButtonStyle}"
                    Content="保存维护信息" />
            <Button Grid.Column="2"
                    MinWidth="110"
                    Margin="10,0,0,0"
                    Command="{Binding CancelCommand}"
                    Style="{StaticResource FlatActionButtonStyle}"
                    Content="取消" />
        </Grid>
    </Grid>
</Window>
