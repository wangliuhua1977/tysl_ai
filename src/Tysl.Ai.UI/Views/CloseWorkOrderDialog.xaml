<Window x:Class="Tysl.Ai.UI.Views.CloseWorkOrderDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="{Binding Title}"
        Width="540"
        Height="560"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="{StaticResource WindowBackgroundBrush}">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel>
            <TextBlock Style="{StaticResource SectionTitleTextStyle}" Text="确认已处理 / 竣工归档" />
            <TextBlock Margin="0,6,0,0"
                       Style="{StaticResource CaptionTextStyle}"
                       Text="这里只做恢复闭环确认，不在主界面展开复杂表单。确认后会把当前恢复工单归档。" />
        </StackPanel>

        <Border Grid.Row="1" Margin="0,18,0,18" Style="{StaticResource PanelCardStyle}">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel Margin="14">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="88" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <TextBlock Style="{StaticResource DetailLabelTextStyle}" Text="点位" />
                        <TextBlock Grid.Column="1" Style="{StaticResource DetailValueTextStyle}" Text="{Binding SiteDisplayName}" />

                        <TextBlock Grid.Row="1" Style="{StaticResource DetailLabelTextStyle}" Text="接入号" />
                        <TextBlock Grid.Row="1" Grid.Column="1" Style="{StaticResource DetailValueTextStyle}" Text="{Binding ProductAccessNumber}" />

                        <TextBlock Grid.Row="2" Style="{StaticResource DetailLabelTextStyle}" Text="异常原因" />
                        <TextBlock Grid.Row="2" Grid.Column="1" Style="{StaticResource DetailValueTextStyle}" Text="{Binding CurrentFaultReason}" TextWrapping="Wrap" />

                        <TextBlock Grid.Row="3" Style="{StaticResource DetailLabelTextStyle}" Text="恢复状态" />
                        <TextBlock Grid.Row="3" Grid.Column="1" Style="{StaticResource DetailValueTextStyle}" Text="{Binding RecoveryStatusText}" />

                        <TextBlock Grid.Row="4" Style="{StaticResource DetailLabelTextStyle}" Text="恢复时间" />
                        <TextBlock Grid.Row="4" Grid.Column="1" Style="{StaticResource DetailValueTextStyle}" Text="{Binding RecoveredAtText}" />

                        <TextBlock Grid.Row="5" Style="{StaticResource DetailLabelTextStyle}" Text="维护人" />
                        <TextBlock Grid.Row="5" Grid.Column="1" Style="{StaticResource DetailValueTextStyle}" Text="{Binding MaintainerName}" />
                    </Grid>

                    <TextBlock Margin="0,14,0,0" Style="{StaticResource DetailLabelTextStyle}" Text="最近通知摘要" />
                    <TextBlock Margin="0,4,0,0"
                               Style="{StaticResource DetailValueTextStyle}"
                               Text="{Binding LastNotificationSummaryText}"
                               TextWrapping="Wrap" />

                    <TextBlock Margin="0,14,0,0" Style="{StaticResource DetailLabelTextStyle}" Text="处理说明（可选）" />
                    <TextBox Margin="0,6,0,0"
                             MinHeight="110"
                             AcceptsReturn="True"
                             TextWrapping="Wrap"
                             VerticalScrollBarVisibility="Auto"
                             Style="{StaticResource DialogMultilineTextBoxStyle}"
                             Text="{Binding ClosingRemark, UpdateSourceTrigger=PropertyChanged}" />
                </StackPanel>
            </ScrollViewer>
        </Border>

        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <Button Grid.Column="1"
                    MinWidth="130"
                    Click="HandleConfirmClick"
                    Style="{StaticResource AccentActionButtonStyle}"
                    Content="确认归档" />
            <Button Grid.Column="2"
                    MinWidth="110"
                    Margin="10,0,0,0"
                    Command="{Binding CancelCommand}"
                    Style="{StaticResource FlatActionButtonStyle}"
                    Content="取消" />
        </Grid>
    </Grid>
</Window>
