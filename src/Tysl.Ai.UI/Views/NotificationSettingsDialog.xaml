<Window x:Class="Tysl.Ai.UI.Views.NotificationSettingsDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Style="{StaticResource ShellWindowStyle}"
        Title="{Binding Title}"
        Width="1120"
        Height="760"
        MinWidth="980"
        MinHeight="680"
        ResizeMode="CanResize">
    <Grid Margin="22">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel>
            <TextBlock FontSize="24" FontWeight="SemiBold" Text="{Binding Title}" />
            <TextBlock Margin="0,6,0,0"
                       Style="{StaticResource CaptionTextStyle}"
                       Text="本地维护派单通知池与恢复通知池地址。这里只管理地址与启停状态，不在主界面直接编辑。" />
        </StackPanel>

        <Grid Grid.Row="1" Margin="0,18,0,18">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1.5*" />
                <ColumnDefinition Width="18" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <ScrollViewer Grid.Column="0"
                          VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled">
                <StackPanel>
                    <Border Style="{StaticResource PanelCardStyle}" Padding="14">
                        <StackPanel>
                            <DockPanel LastChildFill="False">
                                <TextBlock Style="{StaticResource SectionTitleTextStyle}" Text="派单通知池" />
                                <Button DockPanel.Dock="Right"
                                        Command="{Binding AddDispatchEndpointCommand}"
                                        Style="{StaticResource SecondaryEntryButtonStyle}"
                                        Content="新增地址" />
                            </DockPanel>

                            <ItemsControl Margin="0,12,0,0" ItemsSource="{Binding DispatchEndpoints}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Margin="0,0,0,10"
                                                Padding="12"
                                                Background="{StaticResource PanelAltBrush}"
                                                BorderBrush="{StaticResource SubtleBorderBrush}"
                                                BorderThickness="1"
                                                CornerRadius="12">
                                            <Grid>
                                                <Grid.RowDefinitions>
                                                    <RowDefinition Height="Auto" />
                                                    <RowDefinition Height="Auto" />
                                                    <RowDefinition Height="Auto" />
                                                </Grid.RowDefinitions>
                                                <DockPanel LastChildFill="False">
                                                    <TextBlock FontSize="15"
                                                               FontWeight="SemiBold"
                                                               Text="{Binding Name}" />
                                                    <Border DockPanel.Dock="Right"
                                                            Padding="8,2"
                                                            Background="{StaticResource CardBrush}"
                                                            BorderBrush="{StaticResource SubtleBorderBrush}"
                                                            BorderThickness="1"
                                                            CornerRadius="999">
                                                        <TextBlock Style="{StaticResource CaptionTextStyle}" Text="{Binding StatusText}" />
                                                    </Border>
                                                </DockPanel>
                                                <TextBlock Grid.Row="1"
                                                           Margin="0,6,0,0"
                                                           Style="{StaticResource CaptionTextStyle}"
                                                           TextWrapping="Wrap"
                                                           Text="{Binding WebhookUrl}" />
                                                <DockPanel Grid.Row="2" Margin="0,10,0,0" LastChildFill="False">
                                                    <StackPanel>
                                                        <TextBlock Style="{StaticResource MutedTextStyle}"
                                                                   Text="{Binding UsageRemark, TargetNullValue=未填写用途备注}" />
                                                        <TextBlock Margin="0,4,0,0"
                                                                   Style="{StaticResource MutedTextStyle}"
                                                                   Text="{Binding UpdatedAtText, StringFormat=最近更新：{0}}" />
                                                    </StackPanel>
                                                    <WrapPanel DockPanel.Dock="Right" HorizontalAlignment="Right">
                                                        <Button Margin="0,0,8,0"
                                                                Command="{Binding DataContext.EditEndpointCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                                CommandParameter="{Binding}"
                                                                Style="{StaticResource CompactActionButtonStyle}"
                                                                Content="编辑" />
                                                        <Button Margin="0,0,8,0"
                                                                Command="{Binding DataContext.ToggleEndpointCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                                CommandParameter="{Binding}"
                                                                Style="{StaticResource CompactActionButtonStyle}"
                                                                Content="{Binding ToggleText}" />
                                                        <Button Command="{Binding DataContext.DeleteEndpointCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                                CommandParameter="{Binding}"
                                                                Style="{StaticResource CompactActionButtonStyle}"
                                                                Content="删除" />
                                                    </WrapPanel>
                                                </DockPanel>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </Border>

                    <Border Margin="0,14,0,0" Style="{StaticResource PanelCardStyle}" Padding="14">
                        <StackPanel>
                            <DockPanel LastChildFill="False">
                                <TextBlock Style="{StaticResource SectionTitleTextStyle}" Text="恢复通知池" />
                                <Button DockPanel.Dock="Right"
                                        Command="{Binding AddRecoveryEndpointCommand}"
                                        Style="{StaticResource SecondaryEntryButtonStyle}"
                                        Content="新增地址" />
                            </DockPanel>

                            <ItemsControl Margin="0,12,0,0" ItemsSource="{Binding RecoveryEndpoints}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Margin="0,0,0,10"
                                                Padding="12"
                                                Background="{StaticResource PanelAltBrush}"
                                                BorderBrush="{StaticResource SubtleBorderBrush}"
                                                BorderThickness="1"
                                                CornerRadius="12">
                                            <Grid>
                                                <Grid.RowDefinitions>
                                                    <RowDefinition Height="Auto" />
                                                    <RowDefinition Height="Auto" />
                                                    <RowDefinition Height="Auto" />
                                                </Grid.RowDefinitions>
                                                <DockPanel LastChildFill="False">
                                                    <TextBlock FontSize="15"
                                                               FontWeight="SemiBold"
                                                               Text="{Binding Name}" />
                                                    <Border DockPanel.Dock="Right"
                                                            Padding="8,2"
                                                            Background="{StaticResource CardBrush}"
                                                            BorderBrush="{StaticResource SubtleBorderBrush}"
                                                            BorderThickness="1"
                                                            CornerRadius="999">
                                                        <TextBlock Style="{StaticResource CaptionTextStyle}" Text="{Binding StatusText}" />
                                                    </Border>
                                                </DockPanel>
                                                <TextBlock Grid.Row="1"
                                                           Margin="0,6,0,0"
                                                           Style="{StaticResource CaptionTextStyle}"
                                                           TextWrapping="Wrap"
                                                           Text="{Binding WebhookUrl}" />
                                                <DockPanel Grid.Row="2" Margin="0,10,0,0" LastChildFill="False">
                                                    <StackPanel>
                                                        <TextBlock Style="{StaticResource MutedTextStyle}"
                                                                   Text="{Binding UsageRemark, TargetNullValue=未填写用途备注}" />
                                                        <TextBlock Margin="0,4,0,0"
                                                                   Style="{StaticResource MutedTextStyle}"
                                                                   Text="{Binding UpdatedAtText, StringFormat=最近更新：{0}}" />
                                                    </StackPanel>
                                                    <WrapPanel DockPanel.Dock="Right" HorizontalAlignment="Right">
                                                        <Button Margin="0,0,8,0"
                                                                Command="{Binding DataContext.EditEndpointCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                                CommandParameter="{Binding}"
                                                                Style="{StaticResource CompactActionButtonStyle}"
                                                                Content="编辑" />
                                                        <Button Margin="0,0,8,0"
                                                                Command="{Binding DataContext.ToggleEndpointCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                                CommandParameter="{Binding}"
                                                                Style="{StaticResource CompactActionButtonStyle}"
                                                                Content="{Binding ToggleText}" />
                                                        <Button Command="{Binding DataContext.DeleteEndpointCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                                CommandParameter="{Binding}"
                                                                Style="{StaticResource CompactActionButtonStyle}"
                                                                Content="删除" />
                                                    </WrapPanel>
                                                </DockPanel>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </ScrollViewer>

            <Border Grid.Column="2" Style="{StaticResource PanelCardStyle}" Padding="16">
                <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                    <StackPanel>
                        <TextBlock Style="{StaticResource SectionTitleTextStyle}" Text="{Binding EditSectionTitle}" />

                        <TextBlock Style="{StaticResource DialogFieldLabelStyle}" Text="通知池" />
                        <ComboBox Style="{StaticResource DialogComboBoxStyle}"
                                  DisplayMemberPath="Label"
                                  ItemsSource="{Binding PoolOptions}"
                                  SelectedValue="{Binding EditingPool}"
                                  SelectedValuePath="Value" />

                        <TextBlock Style="{StaticResource DialogFieldLabelStyle}" Text="名称" />
                        <TextBox Style="{StaticResource DialogTextBoxStyle}" Text="{Binding EditingName, UpdateSourceTrigger=PropertyChanged}" />

                        <TextBlock Style="{StaticResource DialogFieldLabelStyle}" Text="Webhook 地址" />
                        <TextBox Style="{StaticResource DialogTextBoxStyle}" Text="{Binding EditingWebhookUrl, UpdateSourceTrigger=PropertyChanged}" />

                        <TextBlock Style="{StaticResource DialogFieldLabelStyle}" Text="用途备注" />
                        <TextBox Style="{StaticResource DialogMultilineTextBoxStyle}"
                                 MinHeight="88"
                                 TextWrapping="Wrap"
                                 Text="{Binding EditingUsageRemark, UpdateSourceTrigger=PropertyChanged}" />

                        <TextBlock Style="{StaticResource DialogFieldLabelStyle}" Text="排序号" />
                        <TextBox Style="{StaticResource DialogTextBoxStyle}" Text="{Binding EditingSortOrder, UpdateSourceTrigger=PropertyChanged}" />

                        <CheckBox Style="{StaticResource DialogCheckBoxStyle}"
                                  IsChecked="{Binding EditingIsEnabled}"
                                  Content="启用该地址" />

                        <WrapPanel Margin="0,16,0,0">
                            <Button Margin="0,0,10,0"
                                    Command="{Binding SaveEndpointCommand}"
                                    Style="{StaticResource AccentActionButtonStyle}"
                                    Content="保存地址" />
                            <Button Command="{Binding CancelEditCommand}"
                                    Style="{StaticResource FlatActionButtonStyle}"
                                    Content="清空表单" />
                        </WrapPanel>
                    </StackPanel>
                </ScrollViewer>
            </Border>
        </Grid>

        <Border Grid.Row="2"
                Padding="10,8"
                Background="{StaticResource PanelAltBrush}"
                BorderBrush="{StaticResource SubtleBorderBrush}"
                BorderThickness="1"
                CornerRadius="10">
            <TextBlock Style="{StaticResource CaptionTextStyle}" Text="{Binding StatusText}" />
        </Border>
    </Grid>
</Window>
