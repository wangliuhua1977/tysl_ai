<Window x:Class="Tysl.Ai.UI.Views.NotificationTemplateSettingsDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Style="{StaticResource ShellWindowStyle}"
        Title="{Binding Title}"
        Width="1080"
        Height="760"
        MinWidth="960"
        MinHeight="660"
        ResizeMode="CanResize">
    <Grid Margin="22">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel>
            <TextBlock FontSize="24" FontWeight="SemiBold" Text="{Binding Title}" />
            <TextBlock Margin="0,6,0,0"
                       Style="{StaticResource CaptionTextStyle}"
                       Text="本地维护派单通知模板与恢复通知模板，支持变量说明和预览渲染结果。" />
        </StackPanel>

        <Grid Grid.Row="1" Margin="0,18,0,18">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1.25*" />
                <ColumnDefinition Width="18" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Style="{StaticResource PanelCardStyle}" Padding="16">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <StackPanel>
                        <TextBlock Style="{StaticResource SectionTitleTextStyle}" Text="模板编辑" />
                        <ComboBox Margin="0,12,0,0"
                                  Style="{StaticResource DialogComboBoxStyle}"
                                  DisplayMemberPath="Label"
                                  ItemsSource="{Binding TemplateOptions}"
                                  SelectedValue="{Binding SelectedKind}"
                                  SelectedValuePath="Value" />
                        <TextBlock Margin="0,12,0,0"
                                   Style="{StaticResource CaptionTextStyle}"
                                   Text="{Binding UpdatedAtText, StringFormat=最近保存：{0}}" />
                    </StackPanel>

                    <TextBox Grid.Row="1"
                             Margin="0,16,0,0"
                             AcceptsReturn="True"
                             VerticalScrollBarVisibility="Auto"
                             TextWrapping="Wrap"
                             Style="{StaticResource DialogMultilineTextBoxStyle}"
                             Text="{Binding TemplateContent, UpdateSourceTrigger=PropertyChanged}" />
                </Grid>
            </Border>

            <ScrollViewer Grid.Column="2"
                          VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled">
                <StackPanel>
                    <Border Style="{StaticResource PanelCardStyle}" Padding="16">
                        <StackPanel>
                            <TextBlock Style="{StaticResource SectionTitleTextStyle}" Text="可用变量" />
                            <ItemsControl Margin="0,12,0,0" ItemsSource="{Binding SupportedVariables}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <DockPanel Margin="0,0,0,8" LastChildFill="False">
                                            <Border Padding="8,3"
                                                    Background="{StaticResource PanelAltBrush}"
                                                    BorderBrush="{StaticResource SubtleBorderBrush}"
                                                    BorderThickness="1"
                                                    CornerRadius="999">
                                                <TextBlock Style="{StaticResource CaptionTextStyle}" Text="{Binding Token}" />
                                            </Border>
                                            <TextBlock Margin="10,0,0,0"
                                                       VerticalAlignment="Center"
                                                       Style="{StaticResource MutedTextStyle}"
                                                       Text="{Binding Description}" />
                                        </DockPanel>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </Border>

                    <Border Margin="0,14,0,0" Style="{StaticResource PanelCardStyle}" Padding="16">
                        <StackPanel>
                            <DockPanel LastChildFill="False">
                                <TextBlock Style="{StaticResource SectionTitleTextStyle}" Text="预览结果" />
                                <Button DockPanel.Dock="Right"
                                        Command="{Binding RefreshPreviewCommand}"
                                        Style="{StaticResource SecondaryEntryButtonStyle}"
                                        Content="刷新预览" />
                            </DockPanel>
                            <TextBlock Margin="0,8,0,0"
                                       Style="{StaticResource CaptionTextStyle}"
                                       Text="{Binding PreviewHintText}" />
                            <TextBox Margin="0,12,0,0"
                                     IsReadOnly="True"
                                     AcceptsReturn="True"
                                     VerticalScrollBarVisibility="Auto"
                                     TextWrapping="Wrap"
                                     MinHeight="240"
                                     Style="{StaticResource DialogMultilineTextBoxStyle}"
                                     Text="{Binding PreviewContent, Mode=OneWay}" />
                        </StackPanel>
                    </Border>
                </StackPanel>
            </ScrollViewer>
        </Grid>

        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0"
                    Padding="10,8"
                    Background="{StaticResource PanelAltBrush}"
                    BorderBrush="{StaticResource SubtleBorderBrush}"
                    BorderThickness="1"
                    CornerRadius="10">
                <TextBlock Style="{StaticResource CaptionTextStyle}" Text="{Binding StatusText}" />
            </Border>

            <Button Grid.Column="1"
                    Margin="10,0,0,0"
                    Command="{Binding ResetTemplateCommand}"
                    Style="{StaticResource FlatActionButtonStyle}"
                    Content="恢复默认模板" />
            <Button Grid.Column="2"
                    Margin="10,0,0,0"
                    Command="{Binding SaveTemplateCommand}"
                    Style="{StaticResource AccentActionButtonStyle}"
                    Content="保存模板" />
        </Grid>
    </Grid>
</Window>
