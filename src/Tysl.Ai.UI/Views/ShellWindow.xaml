<Window x:Class="Tysl.Ai.UI.Views.ShellWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:Tysl.Ai.UI.Controls"
        xmlns:controlsView="clr-namespace:Tysl.Ai.UI.Views.Controls"
        xmlns:infrastructure="clr-namespace:Tysl.Ai.UI.Infrastructure"
        Style="{StaticResource ShellWindowStyle}"
        Title="天翼视联AI巡检系统"
        Width="1600"
        Height="960"
        MinWidth="1280"
        MinHeight="820">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
        <infrastructure:SiteVisualStateToBrushConverter x:Key="SiteVisualStateToBrushConverter" />
    </Window.Resources>

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Padding="12,10" Margin="0,0,0,10" Style="{StaticResource PanelCardStyle}">
            <DockPanel LastChildFill="False">
                <TextBlock VerticalAlignment="Center"
                           FontSize="20"
                           FontWeight="SemiBold"
                           Text="天翼视联AI巡检系统" />

                <WrapPanel DockPanel.Dock="Right"
                           HorizontalAlignment="Right"
                           VerticalAlignment="Center">
                    <controls:StatCard Title="全部纳管" Value="{Binding MonitoredCount}" Hint="当前纳入主值守与巡检的点位数" />
                    <controls:StatCard Title="异常" Value="{Binding FaultCount}" Hint="当前需要关注的点位数" />
                    <controls:StatCard Title="正常" Value="{Binding NormalCount}" Hint="当前运行态正常的点位数" />
                    <controls:StatCard Title="派单中 / 待派单" Value="{Binding DispatchQueueText}" Hint="派单链路中的已派单数 / 待派单数" />
                    <controls:StatCard Title="刷新时间" Value="{Binding LastRefreshText}" Hint="最新一次地图查询刷新时间" />
                </WrapPanel>
            </DockPanel>
        </Border>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="336" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Margin="0,0,16,0">
                <Border.Style>
                    <Style TargetType="Border" BasedOn="{StaticResource PanelCardStyle}">
                        <Setter Property="Width" Value="224" />
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsFilterPanelExpanded}" Value="False">
                                <Setter Property="Width" Value="82" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <DockPanel LastChildFill="False">
                        <TextBlock Style="{StaticResource SectionTitleTextStyle}"
                                   Text="筛选"
                                   Visibility="{Binding IsFilterPanelExpanded, Converter={StaticResource BooleanToVisibilityConverter}}" />
                        <Button Width="34"
                                Height="34"
                                HorizontalAlignment="Right"
                                Command="{Binding ToggleFilterPanelCommand}"
                                Style="{StaticResource FlatActionButtonStyle}"
                                ToolTip="展开或收起筛选区"
                                Content="≡" />
                    </DockPanel>

                    <Grid Grid.Row="1"
                          Margin="0,12,0,14"
                          Visibility="{Binding IsFilterPanelExpanded, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <TextBox Style="{StaticResource SearchTextBoxStyle}"
                                 Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                                 ToolTip="按别名、设备名、设备编码或维护信息检索" />
                        <TextBlock Text="搜索点位、设备编码或维护信息">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock" BasedOn="{StaticResource SearchWatermarkTextStyle}">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding SearchText}" Value="">
                                            <Setter Property="Visibility" Value="Visible" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </Grid>

                    <ListBox Grid.Row="2"
                             Style="{StaticResource FilterListBoxStyle}"
                             ItemsSource="{Binding Filters}"
                             SelectedItem="{Binding SelectedFilter}">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Style="{StaticResource FilterListBoxItemTextStyle}"
                                           Text="{Binding Label}" />
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Grid>
            </Border>

            <Border Grid.Column="1" Padding="12" Margin="0,0,10,0" Style="{StaticResource PanelCardStyle}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <DockPanel Margin="0,0,0,8" LastChildFill="False">
                        <StackPanel>
                            <TextBlock Style="{StaticResource SectionTitleTextStyle}" Text="{Binding MapCoverageText}" />
                            <TextBlock Margin="0,2,0,0"
                                       MaxWidth="392"
                                       Style="{StaticResource MutedTextStyle}"
                                       Text="{Binding MapCoverageDetailText}" />
                        </StackPanel>

                        <StackPanel DockPanel.Dock="Right"
                                    Orientation="Horizontal"
                                    VerticalAlignment="Center">
                            <TextBlock Margin="0,0,6,0"
                                       VerticalAlignment="Center"
                                       Style="{StaticResource MutedTextStyle}"
                                       Text="底图" />
                            <ComboBox Width="126"
                                      Margin="0"
                                      DisplayMemberPath="Label"
                                      ItemsSource="{Binding MapStyleOptions}"
                                      SelectedValue="{Binding SelectedMapStyleKey}"
                                      SelectedValuePath="MapStyleKey"
                                      Style="{StaticResource DialogComboBoxStyle}" />
                        </StackPanel>
                    </DockPanel>

                    <Grid Grid.Row="1">
                        <controlsView:AmapHostControl x:Name="AmapHost"
                                                      StateJson="{Binding MapHostStateJson}"
                                                      SelectedMapStyleKey="{Binding SelectedMapStyleKey}" />

                        <Border HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                Padding="16,10"
                                Background="{StaticResource CardBrush}"
                                BorderBrush="{StaticResource SubtleBorderBrush}"
                                BorderThickness="1"
                                CornerRadius="12">
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding HasVisiblePoints}" Value="False">
                                            <Setter Property="Visibility" Value="Visible" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <TextBlock MaxWidth="280"
                                       TextAlignment="Center"
                                       TextWrapping="Wrap"
                                       Style="{StaticResource CaptionTextStyle}"
                                       Text="{Binding MapEmptyStateText}" />
                        </Border>

                        <Border HorizontalAlignment="Center"
                                VerticalAlignment="Top"
                                Margin="0,10,0,0"
                                Padding="10,5"
                                Background="{StaticResource CardBrush}"
                                BorderBrush="{StaticResource AccentBrush}"
                                BorderThickness="1"
                                CornerRadius="12"
                                Visibility="{Binding IsCoordinatePickActive, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <TextBlock Style="{StaticResource CaptionTextStyle}" Text="{Binding MapInteractionHint}" />
                        </Border>
                    </Grid>
                </Grid>
            </Border>

            <Border Grid.Column="2" Padding="12" Style="{StaticResource PanelCardStyle}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <DockPanel LastChildFill="False">
                        <TextBlock Style="{StaticResource SectionTitleTextStyle}" Text="点位详情" />
                        <WrapPanel DockPanel.Dock="Right">
                            <Button Margin="0,0,8,0"
                                    Command="{Binding EditSelectedSiteCommand}"
                                    Style="{StaticResource SecondaryEntryButtonStyle}"
                                    ToolTip="打开当前点位的维护信息编辑窗口"
                                    Content="点位维护" />
                            <Button Command="{Binding ToggleIgnoreCommand}"
                                    Style="{StaticResource SecondaryEntryButtonStyle}"
                                    ToolTip="将当前点位移出主值守视图，或恢复进入主线"
                                    Content="{Binding IgnoreToggleText}" />
                        </WrapPanel>
                    </DockPanel>

                    <ScrollViewer Grid.Row="1"
                                  Margin="0,10,0,0"
                                  VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Disabled">
                        <StackPanel>
                            <TextBlock FontSize="18"
                                       FontWeight="SemiBold"
                                       Text="{Binding SelectedDetail.DisplayName, TargetNullValue=未选择点位}" />
                            <TextBlock Margin="0,3,0,0"
                                       Style="{StaticResource MutedTextStyle}"
                                       Text="{Binding SelectedDetail.DeviceName}" />

                            <WrapPanel Margin="0,8,0,0">
                                <Border HorizontalAlignment="Left"
                                        Padding="8,3"
                                        Background="{Binding SelectedDetail.VisualState, Converter={StaticResource SiteVisualStateToBrushConverter}, ConverterParameter=FillBrush}"
                                        BorderBrush="{Binding SelectedDetail.VisualState, Converter={StaticResource SiteVisualStateToBrushConverter}, ConverterParameter=BorderBrush}"
                                        BorderThickness="1"
                                        CornerRadius="999">
                                    <TextBlock Foreground="{Binding SelectedDetail.VisualState, Converter={StaticResource SiteVisualStateToBrushConverter}, ConverterParameter=TextBrush}"
                                               FontSize="12"
                                               Text="{Binding SelectedDetail.StatusText, TargetNullValue=等待选择点位}" />
                                </Border>
                                <Border Margin="8,0,0,0"
                                        Padding="8,3"
                                        Background="{StaticResource PanelAltBrush}"
                                        BorderBrush="{StaticResource SubtleBorderBrush}"
                                        BorderThickness="1"
                                        CornerRadius="999">
                                    <TextBlock Style="{StaticResource MutedTextStyle}"
                                               Text="{Binding SelectedDetail.DispatchHeadlineText, TargetNullValue=未触发派单 / 未恢复}" />
                                </Border>
                            </WrapPanel>

                            <TextBlock Margin="0,12,0,0" Style="{StaticResource SubsectionTitleTextStyle}" Text="产品信息" />
                            <Border Margin="0,8,0,0"
                                    Padding="9"
                                    Background="{StaticResource PanelAltBrush}"
                                    BorderBrush="{StaticResource SubtleBorderBrush}"
                                    BorderThickness="1"
                                    CornerRadius="12">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="68" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>

                                    <TextBlock Style="{StaticResource DetailLabelTextStyle}" Text="接入号" />
                                    <TextBlock Grid.Column="1"
                                               Style="{StaticResource DetailValueTextStyle}"
                                               Text="{Binding SelectedDetail.ProductAccessNumber, TargetNullValue=未补充}" />

                                    <TextBlock Grid.Row="1"
                                               Style="{StaticResource DetailLabelTextStyle}"
                                               Text="产品状态" />
                                    <TextBlock Grid.Row="1"
                                               Grid.Column="1"
                                               Style="{StaticResource DetailValueTextStyle}"
                                               Text="{Binding SelectedDetail.ProductStatusText, TargetNullValue=待接入}" />

                                    <TextBlock Grid.Row="2"
                                               Style="{StaticResource DetailLabelTextStyle}"
                                               Text="欠费金额" />
                                    <TextBlock Grid.Row="2"
                                               Grid.Column="1"
                                               Style="{StaticResource DetailValueTextStyle}"
                                               Text="{Binding SelectedDetail.ArrearsAmountText, TargetNullValue=待接入}" />
                                </Grid>
                            </Border>

                            <TextBlock Margin="0,12,0,0" Style="{StaticResource SubsectionTitleTextStyle}" Text="异常原因" />
                            <Border Margin="0,8,0,0"
                                    Padding="9,8"
                                    Background="{StaticResource PanelAltBrush}"
                                    BorderBrush="{StaticResource SubtleBorderBrush}"
                                    BorderThickness="1"
                                    CornerRadius="12">
                                <TextBlock Style="{StaticResource DetailValueTextStyle}"
                                           Foreground="{StaticResource TextMutedBrush}"
                                           TextWrapping="Wrap"
                                           Text="{Binding SelectedDetail.AbnormalReasonText, TargetNullValue=选择点位后查看异常原因}" />
                            </Border>

                            <TextBlock Margin="0,12,0,0" Style="{StaticResource SubsectionTitleTextStyle}" Text="主画面" />
                            <StackPanel Margin="0,7,0,0">
                                <DockPanel LastChildFill="False">
                                    <TextBlock VerticalAlignment="Center"
                                               Style="{StaticResource CaptionTextStyle}"
                                               Text="{Binding PreviewStatusText}" />
                                    <Border DockPanel.Dock="Right"
                                            Margin="6,0,0,0"
                                            Style="{StaticResource CompactStatusPillStyle}"
                                            Visibility="{Binding HasPreviewProtocolBadge, Converter={StaticResource BooleanToVisibilityConverter}}">
                                        <TextBlock Style="{StaticResource MutedTextStyle}"
                                                   Text="{Binding PreviewProtocolText}" />
                                    </Border>
                                </DockPanel>

                                <Border Margin="0,6,0,0"
                                        Padding="0"
                                        Background="{StaticResource PanelAltBrush}"
                                        BorderBrush="{StaticResource SubtleBorderBrush}"
                                        BorderThickness="1"
                                        CornerRadius="12"
                                        Visibility="{Binding ShowMediaSurface, Converter={StaticResource BooleanToVisibilityConverter}}">
                                    <Grid>
                                        <controlsView:PreviewHostControl x:Name="PreviewHost"
                                                                         SessionJson="{Binding PreviewSessionJson}"
                                                                         Height="186"
                                                                         Visibility="{Binding IsPreviewPlaybackReady, Converter={StaticResource BooleanToVisibilityConverter}}" />

                                        <Border CornerRadius="12"
                                                BorderBrush="{StaticResource SubtleBorderBrush}"
                                                BorderThickness="0"
                                                Background="{StaticResource CardBrush}"
                                                Visibility="{Binding HasSnapshotFallback, Converter={StaticResource BooleanToVisibilityConverter}}">
                                            <Image Height="156"
                                                   Stretch="UniformToFill"
                                                   Source="{Binding SelectedDetail.LastSnapshotPath}" />
                                        </Border>
                                    </Grid>
                                </Border>

                                <TextBlock Margin="0,6,0,0"
                                           HorizontalAlignment="Left"
                                           Style="{StaticResource CaptionTextStyle}"
                                           Visibility="{Binding ShowMediaEmptyState, Converter={StaticResource BooleanToVisibilityConverter}}"
                                           Text="{Binding MediaEmptyStateText}" />

                                <WrapPanel Margin="0,6,0,0"
                                           HorizontalAlignment="Right">
                                    <Button Margin="0,0,8,0"
                                            Command="{Binding OpenPreviewCommand}"
                                            Style="{StaticResource CompactActionButtonStyle}"
                                            Content="重连预览" />
                                    <Button Command="{Binding ClosePreviewCommand}"
                                            Style="{StaticResource CompactActionButtonStyle}"
                                            Content="停止" />
                                </WrapPanel>
                            </StackPanel>

                            <TextBlock Margin="0,12,0,0" Style="{StaticResource SubsectionTitleTextStyle}" Text="派单" />
                            <Border Margin="0,7,0,0"
                                    Padding="9"
                                    Background="{StaticResource PanelAltBrush}"
                                    BorderBrush="{StaticResource SubtleBorderBrush}"
                                    BorderThickness="1"
                                    CornerRadius="12">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>

                                    <DockPanel LastChildFill="False">
                                        <TextBlock Style="{StaticResource DetailValueTextStyle}"
                                                   Text="{Binding SelectedDetail.DispatchStatusText}" />
                                        <WrapPanel DockPanel.Dock="Right">
                                            <Button Command="{Binding ConfirmRecoveryCommand}"
                                                    Visibility="{Binding SelectedDetail.CanConfirmRecovery, Converter={StaticResource BooleanToVisibilityConverter}}"
                                                    Style="{StaticResource CompactActionButtonStyle}"
                                                    ToolTip="打开恢复归档确认窗口"
                                                    Content="{Binding SelectedDetail.CloseActionText}" />
                                            <Button Margin="8,0,0,0"
                                                    Command="{Binding ManualDispatchCommand}"
                                                    Style="{StaticResource PrimaryCompactActionButtonStyle}"
                                                    ToolTip="打开手工派单确认窗口"
                                                    Content="{Binding ManualDispatchText}" />
                                        </WrapPanel>
                                    </DockPanel>

                                    <Grid Grid.Row="1" Margin="0,7,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="58" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                        </Grid.RowDefinitions>
                                        <TextBlock Style="{StaticResource DetailLabelTextStyle}" Text="触发" />
                                        <TextBlock Grid.Column="1"
                                                   Style="{StaticResource DetailValueTextStyle}"
                                                   Text="{Binding SelectedDetail.DispatchTriggeredAtText}" />
                                        <TextBlock Grid.Row="1"
                                                   Style="{StaticResource DetailLabelTextStyle}"
                                                   Text="最近发送" />
                                        <TextBlock Grid.Row="1"
                                                   Grid.Column="1"
                                                   Style="{StaticResource DetailValueTextStyle}"
                                                   Text="{Binding SelectedDetail.LastDispatchAtText}" />
                                        <TextBlock Grid.Row="2"
                                                   Style="{StaticResource DetailLabelTextStyle}"
                                                   Text="恢复状态" />
                                        <TextBlock Grid.Row="2"
                                                   Grid.Column="1"
                                                   Style="{StaticResource DetailValueTextStyle}"
                                                   Text="{Binding SelectedDetail.RecoveryStatusText}" />
                                        <TextBlock Grid.Row="3"
                                                   Style="{StaticResource DetailLabelTextStyle}"
                                                   Text="恢复时间" />
                                        <TextBlock Grid.Row="3"
                                                   Grid.Column="1"
                                                   Style="{StaticResource DetailValueTextStyle}"
                                                   Text="{Binding SelectedDetail.RecoveredAtText}" />
                                        <TextBlock Grid.Row="4"
                                                   Style="{StaticResource DetailLabelTextStyle}"
                                                   Text="归档时间" />
                                        <TextBlock Grid.Row="4"
                                                   Grid.Column="1"
                                                   Style="{StaticResource DetailValueTextStyle}"
                                                   Text="{Binding SelectedDetail.ClosedArchivedAtText}" />
                                        <TextBlock Grid.Row="5"
                                                   Style="{StaticResource DetailLabelTextStyle}"
                                                   Text="恢复方式" />
                                        <TextBlock Grid.Row="5"
                                                   Grid.Column="1"
                                                   Style="{StaticResource DetailValueTextStyle}"
                                                   Text="{Binding SelectedDetail.RecoverySourceText}" />
                                    </Grid>

                                    <StackPanel Grid.Row="2" Margin="0,10,0,0">
                                        <TextBlock Style="{StaticResource CaptionTextStyle}"
                                                   Text="{Binding SelectedDetail.RecoverySummaryText}" />
                                        <TextBlock Margin="0,4,0,0"
                                                   Style="{StaticResource CaptionTextStyle}"
                                                   Text="{Binding SelectedDetail.LastNotificationSummaryText}" />
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </StackPanel>
                    </ScrollViewer>
                </Grid>
            </Border>
        </Grid>

        <Border Grid.Row="2" Padding="12" Margin="0,10,0,0" Style="{StaticResource PanelCardStyle}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="14" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel>
                    <TextBlock Style="{StaticResource SectionTitleTextStyle}" Text="异常缩略条" />
                    <ScrollViewer Margin="0,8,0,0" HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled">
                        <ItemsControl ItemsSource="{Binding VisibleAlerts}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <StackPanel Orientation="Horizontal" />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Button Margin="0,0,8,0"
                                            MinWidth="0"
                                            Command="{Binding DataContext.SelectAlertCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                            CommandParameter="{Binding}"
                                            Style="{StaticResource AlertSelectButtonStyle}">
                                        <Border Padding="8,6"
                                                Background="{StaticResource PanelAltBrush}"
                                                BorderBrush="{StaticResource SubtleBorderBrush}"
                                                BorderThickness="1"
                                                CornerRadius="10">
                                            <Grid Width="156">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="4" />
                                                    <ColumnDefinition Width="*" />
                                                </Grid.ColumnDefinitions>
                                                <Border Width="4"
                                                        Background="{StaticResource Status.Alert.BorderBrush}"
                                                        CornerRadius="2" />
                                                <StackPanel Grid.Column="1" Margin="10,0,0,0">
                                                    <TextBlock FontWeight="SemiBold"
                                                               FontSize="12"
                                                               TextTrimming="CharacterEllipsis"
                                                               Text="{Binding PointDisplayName}" />
                                                    <TextBlock Margin="0,4,0,0"
                                                               Style="{StaticResource CaptionTextStyle}"
                                                               Text="{Binding IssueLabel}" />
                                                    <TextBlock Margin="0,3,0,0"
                                                               Style="{StaticResource MutedTextStyle}"
                                                               Text="{Binding OccurredAtText, StringFormat=最近变化：{0}}" />
                                                </StackPanel>
                                            </Grid>
                                        </Border>
                                    </Button>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </StackPanel>

                <StackPanel Grid.Column="2" Width="224" HorizontalAlignment="Right">
                    <WrapPanel HorizontalAlignment="Right">
                        <Button Margin="0,0,8,0"
                                Command="{Binding OpenNotificationSettingsCommand}"
                                Style="{StaticResource SecondaryEntryButtonStyle}"
                                ToolTip="打开本地通知地址管理"
                                Content="通知设置" />
                        <Button Margin="0,0,8,0"
                                Command="{Binding OpenTemplateSettingsCommand}"
                                Style="{StaticResource SecondaryEntryButtonStyle}"
                                ToolTip="打开本地通知模板管理"
                                Content="模板设置" />
                        <Button Margin="0,0,8,0"
                                Command="{Binding OpenUnmappedSecondaryEntryCommand}"
                                Style="{StaticResource SecondaryEntryButtonStyle}"
                                ToolTip="打开未落图治理列表"
                                Content="未落图治理" />
                        <Button Command="{Binding OpenIgnoredSecondaryEntryCommand}"
                                Style="{StaticResource SecondaryEntryButtonStyle}"
                                ToolTip="打开已忽略点位列表"
                                Content="已忽略点位" />
                    </WrapPanel>

                    <Border Margin="0,8,0,0"
                            Padding="9"
                            Width="224"
                            Background="{StaticResource PanelAltBrush}"
                            BorderBrush="{StaticResource SubtleBorderBrush}"
                            BorderThickness="1"
                            CornerRadius="12"
                            Visibility="{Binding IsSecondaryPanelOpen, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>

                            <DockPanel LastChildFill="False">
                                <TextBlock Style="{StaticResource MutedTextStyle}" Text="{Binding SecondarySectionTitle}" />
                                <Button DockPanel.Dock="Right"
                                        Width="24"
                                        Height="24"
                                        Padding="0"
                                        Command="{Binding CloseSecondaryPanelCommand}"
                                        Style="{StaticResource CompactActionButtonStyle}"
                                        Content="×" />
                            </DockPanel>

                            <ScrollViewer Grid.Row="1"
                                          Margin="0,7,0,0"
                                          MaxHeight="136"
                                          VerticalScrollBarVisibility="Auto"
                                          HorizontalScrollBarVisibility="Disabled">
                                <StackPanel>
                                    <ItemsControl ItemsSource="{Binding UnmappedPoints}">
                                        <ItemsControl.Style>
                                            <Style TargetType="ItemsControl">
                                                <Setter Property="Visibility" Value="Visible" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsIgnoredSecondaryMode}" Value="True">
                                                        <Setter Property="Visibility" Value="Collapsed" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </ItemsControl.Style>
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Grid Margin="0,0,0,8">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="Auto" />
                                                    </Grid.ColumnDefinitions>
                                                    <Button Command="{Binding DataContext.SelectUnmappedPointCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                            CommandParameter="{Binding}"
                                                            MinWidth="0"
                                                            Style="{StaticResource AlertSelectButtonStyle}">
                                                        <Border Padding="9,7"
                                                                Background="{StaticResource CardBrush}"
                                                                BorderBrush="{StaticResource SubtleBorderBrush}"
                                                                BorderThickness="1"
                                                                CornerRadius="10">
                                                            <StackPanel>
                                                                <TextBlock FontWeight="SemiBold"
                                                                           TextTrimming="CharacterEllipsis"
                                                                           Text="{Binding DisplayName}" />
                                                                <TextBlock Margin="0,4,0,0"
                                                                           Style="{StaticResource MutedTextStyle}"
                                                                           Text="{Binding UnmappedReasonText}" />
                                                            </StackPanel>
                                                        </Border>
                                                    </Button>
                                                    <Button Grid.Column="1"
                                                            Margin="8,0,0,0"
                                                            Command="{Binding DataContext.EditUnmappedPointCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                            CommandParameter="{Binding}"
                                                            Style="{StaticResource CompactActionButtonStyle}"
                                                            Content="补坐标" />
                                                </Grid>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>

                                    <ItemsControl ItemsSource="{Binding IgnoredPoints}">
                                        <ItemsControl.Style>
                                            <Style TargetType="ItemsControl">
                                                <Setter Property="Visibility" Value="Collapsed" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsIgnoredSecondaryMode}" Value="True">
                                                        <Setter Property="Visibility" Value="Visible" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </ItemsControl.Style>
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Button Margin="0,0,0,8"
                                                        MinWidth="0"
                                                        Command="{Binding DataContext.SelectIgnoredPointCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                        CommandParameter="{Binding}"
                                                        Style="{StaticResource AlertSelectButtonStyle}">
                                                    <Border Padding="9,7"
                                                            Background="{StaticResource CardBrush}"
                                                            BorderBrush="{StaticResource SubtleBorderBrush}"
                                                            BorderThickness="1"
                                                            CornerRadius="10">
                                                        <StackPanel>
                                                            <TextBlock FontWeight="SemiBold"
                                                                       TextTrimming="CharacterEllipsis"
                                                                       Text="{Binding DisplayName}" />
                                                            <TextBlock Margin="0,4,0,0"
                                                                       Style="{StaticResource MutedTextStyle}"
                                                                       Text="{Binding IgnoredAtText, StringFormat=忽略时间：{0}}" />
                                                        </StackPanel>
                                                    </Border>
                                                </Button>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>

                                    <Border Padding="9,7"
                                            Background="{StaticResource CardBrush}"
                                            BorderBrush="{StaticResource SubtleBorderBrush}"
                                            BorderThickness="1"
                                            CornerRadius="10">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="Visibility" Value="Collapsed" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding HasSecondaryItems}" Value="False">
                                                        <Setter Property="Visibility" Value="Visible" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <TextBlock Style="{StaticResource MutedTextStyle}"
                                                   Text="{Binding SecondarySectionEmptyText}" />
                                    </Border>
                                </StackPanel>
                            </ScrollViewer>
                        </Grid>
                    </Border>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
