<Window x:Class="Tysl.Ai.UI.Views.ShellWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:Tysl.Ai.UI.Controls"
        xmlns:controlsView="clr-namespace:Tysl.Ai.UI.Views.Controls"
        xmlns:infrastructure="clr-namespace:Tysl.Ai.UI.Infrastructure"
        Style="{StaticResource ShellWindowStyle}"
        Title="天枢视联 AI 巡检系统"
        Width="1600"
        Height="960"
        MinWidth="1280"
        MinHeight="820">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
        <infrastructure:SiteVisualStateToBrushConverter x:Key="SiteVisualStateToBrushConverter" />
    </Window.Resources>

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Padding="20" Margin="0,0,0,16" Style="{StaticResource PanelCardStyle}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="420" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <StackPanel>
                    <TextBlock FontSize="26" FontWeight="SemiBold" Text="天枢视联 AI 巡检系统" />
                    <TextBlock Margin="0,6,0,0"
                               Style="{StaticResource CaptionTextStyle}"
                               Text="地图主视图持续承载平台点位，右侧抽屉只展示详情与本地补充信息。" />
                    <Border Margin="0,14,0,0"
                            Padding="12,6"
                            HorizontalAlignment="Left"
                            Background="{StaticResource PanelAltBrush}"
                            BorderBrush="{StaticResource SubtleBorderBrush}"
                            BorderThickness="1"
                            CornerRadius="999"
                            ToolTip="{Binding PlatformStatusDetail}">
                        <StackPanel Orientation="Horizontal">
                            <Ellipse Width="8" Height="8" Margin="0,4,8,0" Fill="{StaticResource AccentBrush}" />
                            <TextBlock Style="{StaticResource CaptionTextStyle}" Text="{Binding PlatformStatusText}" />
                        </StackPanel>
                    </Border>
                </StackPanel>

                <StackPanel Grid.Column="1"
                            Orientation="Horizontal"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Center">
                    <controls:StatCard Title="点位数" Value="{Binding PointCount}" Hint="当前平台设备快照中的点位总数" />
                    <controls:StatCard Title="已监测" Value="{Binding MonitoredCount}" Hint="当前纳入监测的点位数量" />
                    <controls:StatCard Title="异常数" Value="{Binding FaultCount}" Hint="异常、离线或待处置点位数量" />
                    <controls:StatCard Title="处置中" Value="{Binding DispatchedCount}" Hint="当前存在派单或恢复处理状态的点位数量" />
                    <controls:StatCard Title="最后刷新" Value="{Binding LastRefreshText}" Hint="当前地图查询刷新时间" />
                </StackPanel>
            </Grid>
        </Border>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="348" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Margin="0,0,16,0">
                <Border.Style>
                    <Style TargetType="Border" BasedOn="{StaticResource PanelCardStyle}">
                        <Setter Property="Width" Value="248" />
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsFilterPanelExpanded}" Value="False">
                                <Setter Property="Width" Value="92" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <DockPanel>
                        <TextBlock Style="{StaticResource SectionTitleTextStyle}"
                                   Text="筛选"
                                   Visibility="{Binding IsFilterPanelExpanded, Converter={StaticResource BooleanToVisibilityConverter}}" />
                        <Button Width="34"
                                Height="34"
                                HorizontalAlignment="Right"
                                Command="{Binding ToggleFilterPanelCommand}"
                                Style="{StaticResource FlatActionButtonStyle}"
                                ToolTip="展开或收起筛选栏"
                                Content="≡" />
                    </DockPanel>

                    <TextBox Grid.Row="1"
                             Margin="0,14,0,16"
                             Style="{StaticResource SearchTextBoxStyle}"
                             Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                             ToolTip="按别名、设备名、设备编码或维护信息筛选"
                             Visibility="{Binding IsFilterPanelExpanded, Converter={StaticResource BooleanToVisibilityConverter}}" />

                    <ListBox Grid.Row="2"
                             Style="{StaticResource FilterListBoxStyle}"
                             DisplayMemberPath="Label"
                             ItemsSource="{Binding Filters}"
                             SelectedItem="{Binding SelectedFilter}" />
                </Grid>
            </Border>

            <Border Grid.Column="1" Padding="18" Margin="0,0,16,0" Style="{StaticResource PanelCardStyle}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <DockPanel Margin="0,0,0,14">
                        <TextBlock Style="{StaticResource SectionTitleTextStyle}" Text="地图主视图" />
                        <TextBlock HorizontalAlignment="Right"
                                   Style="{StaticResource CaptionTextStyle}"
                                   Text="{Binding MapInteractionHint}" />
                    </DockPanel>

                    <Grid Grid.Row="1">
                        <controlsView:AmapHostControl x:Name="AmapHost"
                                                      StateJson="{Binding MapHostStateJson}" />

                        <Border HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                Padding="18,12"
                                Background="{StaticResource CardBrush}"
                                BorderBrush="{StaticResource SubtleBorderBrush}"
                                BorderThickness="1"
                                CornerRadius="14">
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding HasVisiblePoints}" Value="False">
                                            <Setter Property="Visibility" Value="Visible" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <TextBlock MaxWidth="280"
                                       TextAlignment="Center"
                                       TextWrapping="Wrap"
                                       Style="{StaticResource CaptionTextStyle}"
                                       Text="{Binding MapEmptyStateText}" />
                        </Border>

                        <Border HorizontalAlignment="Center"
                                VerticalAlignment="Top"
                                Margin="0,18,0,0"
                                Padding="14,8"
                                Background="{StaticResource CardBrush}"
                                BorderBrush="{StaticResource AccentBrush}"
                                BorderThickness="1"
                                CornerRadius="12"
                                Visibility="{Binding IsCoordinatePickActive, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <TextBlock Style="{StaticResource CaptionTextStyle}" Text="手工坐标补录中，请点击地图回填经纬度。" />
                        </Border>
                    </Grid>
                </Grid>
            </Border>

            <Border Grid.Column="2" Style="{StaticResource PanelCardStyle}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <TextBlock Style="{StaticResource SectionTitleTextStyle}" Text="点位详情" />

                    <ScrollViewer Grid.Row="1"
                                  Margin="0,16,0,16"
                                  VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Disabled">
                        <StackPanel>
                            <TextBlock FontSize="22" FontWeight="SemiBold" Text="{Binding SelectedDetail.DisplayName, TargetNullValue=未选择点位}" />
                            <TextBlock Margin="0,6,0,0" Style="{StaticResource CaptionTextStyle}" Text="{Binding SelectedDetail.DeviceName}" />
                            <Border Margin="0,14,0,0"
                                    HorizontalAlignment="Left"
                                    Padding="10,5"
                                    Background="{Binding SelectedDetail.VisualState, Converter={StaticResource SiteVisualStateToBrushConverter}, ConverterParameter=FillBrush}"
                                    BorderBrush="{Binding SelectedDetail.VisualState, Converter={StaticResource SiteVisualStateToBrushConverter}, ConverterParameter=BorderBrush}"
                                    BorderThickness="1"
                                    CornerRadius="10">
                                <TextBlock Foreground="{Binding SelectedDetail.VisualState, Converter={StaticResource SiteVisualStateToBrushConverter}, ConverterParameter=TextBrush}"
                                           Text="{Binding SelectedDetail.StatusText, TargetNullValue=等待选择点位}" />
                            </Border>
                            <TextBlock Margin="0,10,0,0"
                                       Style="{StaticResource CaptionTextStyle}"
                                       Text="{Binding SelectedDetail.DispatchHeadlineText, TargetNullValue=派单：未触发 / 恢复：未恢复}" />

                            <TextBlock Margin="0,18,0,0" Style="{StaticResource SectionTitleTextStyle}" Text="主档与补充信息" />
                            <TextBlock Margin="0,10,0,0" Style="{StaticResource DetailValueTextStyle}" Text="{Binding SelectedDetail.DeviceCode, StringFormat=设备编码：{0}}" />
                            <TextBlock Margin="0,6,0,0" Style="{StaticResource DetailValueTextStyle}" Text="{Binding SelectedDetail.Alias, StringFormat=别名：{0}}" />
                            <TextBlock Margin="0,6,0,0" Style="{StaticResource DetailValueTextStyle}" Text="{Binding SelectedDetail.OnlineStateText, StringFormat=在线状态：{0}}" />
                            <TextBlock Margin="0,6,0,0" Style="{StaticResource DetailValueTextStyle}" Text="{Binding SelectedDetail.MonitoringText, StringFormat=监测状态：{0}}" />
                            <TextBlock Margin="0,6,0,0" Style="{StaticResource DetailValueTextStyle}" Text="{Binding SelectedDetail.LocalProfileStatusText}" />
                            <TextBlock Margin="0,6,0,0" Style="{StaticResource DetailValueTextStyle}" Text="{Binding SelectedDetail.AddressText, StringFormat=地址：{0}}" />

                            <TextBlock Margin="0,18,0,0" Style="{StaticResource SectionTitleTextStyle}" Text="运行态" />
                            <TextBlock Margin="0,10,0,0" Style="{StaticResource DetailValueTextStyle}" Text="{Binding SelectedDetail.LastInspectionAtText, StringFormat=最近巡检：{0}}" />
                            <TextBlock Margin="0,6,0,0" Style="{StaticResource DetailValueTextStyle}" Text="{Binding SelectedDetail.LastInspectionRunStateText, StringFormat=巡检结果：{0}}" />
                            <TextBlock Margin="0,6,0,0" Style="{StaticResource DetailValueTextStyle}" Text="{Binding SelectedDetail.LastPreviewResolveStateText, StringFormat=预览解析：{0}}" />
                            <TextBlock Margin="0,6,0,0" Style="{StaticResource DetailValueTextStyle}" Text="{Binding SelectedDetail.LastProductStateText, StringFormat=平台状态：{0}}" />
                            <TextBlock Margin="0,6,0,0" Style="{StaticResource DetailValueTextStyle}" Text="{Binding SelectedDetail.ConsecutiveFailureText, StringFormat=连续失败：{0}}" />
                            <TextBlock Margin="0,6,0,0" Foreground="{StaticResource TextMutedBrush}" TextWrapping="Wrap" Text="{Binding SelectedDetail.RuntimeSummaryText}" />

                            <TextBlock Margin="0,18,0,0" Style="{StaticResource SectionTitleTextStyle}" Text="派单处置" />
                            <TextBlock Margin="0,10,0,0" Style="{StaticResource DetailValueTextStyle}" Text="{Binding SelectedDetail.DispatchStatusText, StringFormat=当前派单状态：{0}}" />
                            <TextBlock Margin="0,6,0,0" Style="{StaticResource DetailValueTextStyle}" Text="{Binding SelectedDetail.DispatchTriggeredAtText, StringFormat=最近触发时间：{0}}" />
                            <TextBlock Margin="0,6,0,0" Style="{StaticResource DetailValueTextStyle}" Text="{Binding SelectedDetail.LastDispatchAtText, StringFormat=最近派单时间：{0}}" />
                            <TextBlock Margin="0,6,0,0" Style="{StaticResource DetailValueTextStyle}" Text="{Binding SelectedDetail.CoolingUntilText, StringFormat=冷却到期时间：{0}}" />
                            <TextBlock Margin="0,6,0,0" Style="{StaticResource DetailValueTextStyle}" Text="{Binding SelectedDetail.RecoveryStatusText, StringFormat=恢复状态：{0}}" />
                            <TextBlock Margin="0,6,0,0" Style="{StaticResource DetailValueTextStyle}" Text="{Binding SelectedDetail.RecoveredAtText, StringFormat=恢复时间：{0}}" />
                            <TextBlock Margin="0,6,0,0" Foreground="{StaticResource TextMutedBrush}" TextWrapping="Wrap" Text="{Binding SelectedDetail.RecoverySummaryText}" />
                            <Button Margin="0,10,0,0"
                                    HorizontalAlignment="Left"
                                    Command="{Binding ConfirmRecoveryCommand}"
                                    Style="{StaticResource FlatActionButtonStyle}"
                                    Visibility="{Binding SelectedDetail.CanConfirmRecovery, Converter={StaticResource BooleanToVisibilityConverter}}"
                                    Content="确认恢复" />

                            <TextBlock Margin="0,18,0,0" Style="{StaticResource SectionTitleTextStyle}" Text="最近截图留痕" />
                            <TextBlock Margin="0,10,0,0" Style="{StaticResource DetailValueTextStyle}" Text="{Binding SelectedDetail.LastSnapshotAtText, StringFormat=最近截图：{0}}" />
                            <Border Margin="0,10,0,0"
                                    CornerRadius="12"
                                    BorderBrush="{StaticResource SubtleBorderBrush}"
                                    BorderThickness="1"
                                    Background="{StaticResource PanelAltBrush}"
                                    Visibility="{Binding SelectedDetail.HasSnapshot, Converter={StaticResource BooleanToVisibilityConverter}}">
                                <Image Height="160"
                                       Stretch="UniformToFill"
                                       Source="{Binding SelectedDetail.LastSnapshotPath}" />
                            </Border>
                            <TextBlock Margin="0,6,0,0"
                                       Style="{StaticResource DetailValueTextStyle}"
                                       Text="{Binding SelectedDetail.LastSnapshotPath, TargetNullValue=暂无截图文件}" />

                            <TextBlock Margin="0,18,0,0" Style="{StaticResource SectionTitleTextStyle}" Text="坐标与平台" />
                            <TextBlock Margin="0,10,0,0" Style="{StaticResource DetailValueTextStyle}" Text="{Binding SelectedDetail.CoordinateSourceText, StringFormat=当前坐标来源：{0}}" />
                            <TextBlock Margin="0,6,0,0" Style="{StaticResource DetailValueTextStyle}" Text="{Binding SelectedDetail.CoordinateStatusText, StringFormat=坐标状态：{0}}" />
                            <TextBlock Margin="0,6,0,0" Style="{StaticResource DetailValueTextStyle}" Text="{Binding SelectedDetail.LongitudeText, StringFormat=当前显示经度：{0}}" />
                            <TextBlock Margin="0,6,0,0" Style="{StaticResource DetailValueTextStyle}" Text="{Binding SelectedDetail.LatitudeText, StringFormat=当前显示纬度：{0}}" />
                            <TextBlock Margin="0,6,0,0" Style="{StaticResource DetailValueTextStyle}" Text="{Binding SelectedDetail.PlatformCoordinateText, StringFormat=平台原始坐标：{0}}" />
                            <TextBlock Margin="0,6,0,0" Style="{StaticResource DetailValueTextStyle}" Text="{Binding SelectedDetail.ManualCoordinateText, StringFormat=本地手工坐标：{0}}" />
                            <TextBlock Margin="0,6,0,0" Style="{StaticResource DetailValueTextStyle}" Text="{Binding SelectedDetail.PlatformStatusSummary, StringFormat=平台连接：{0}}" />
                            <TextBlock Margin="0,6,0,0" Style="{StaticResource DetailValueTextStyle}" Text="{Binding SelectedDetail.ProductAccessNumber, StringFormat=接入号：{0}}" />

                            <TextBlock Margin="0,18,0,0" Style="{StaticResource SectionTitleTextStyle}" Text="维护信息" />
                            <TextBlock Margin="0,10,0,0" Style="{StaticResource DetailValueTextStyle}" Text="{Binding SelectedDetail.MaintenanceUnit, StringFormat=单位：{0}}" />
                            <TextBlock Margin="0,6,0,0" Style="{StaticResource DetailValueTextStyle}" Text="{Binding SelectedDetail.MaintainerName, StringFormat=维护人：{0}}" />
                            <TextBlock Margin="0,6,0,0" Style="{StaticResource DetailValueTextStyle}" Text="{Binding SelectedDetail.MaintainerPhone, StringFormat=电话：{0}}" />

                            <TextBlock Margin="0,18,0,0" Style="{StaticResource SectionTitleTextStyle}" Text="备注" />
                            <TextBlock Margin="0,10,0,0" Style="{StaticResource DetailValueTextStyle}" Text="{Binding SelectedDetail.UpdatedAtText, StringFormat=本地更新时间：{0}}" />
                            <TextBlock Margin="0,10,0,0" Foreground="{StaticResource TextMutedBrush}" TextWrapping="Wrap" Text="{Binding SelectedDetail.Remark}" />
                        </StackPanel>
                    </ScrollViewer>

                    <UniformGrid Grid.Row="2" Columns="2">
                        <Button Margin="0,0,8,0"
                                Command="{Binding EditSelectedSiteCommand}"
                                Style="{StaticResource FlatActionButtonStyle}"
                                ToolTip="打开弹窗维护当前点位的本地补充信息"
                                Content="编辑补充信息" />
                        <Button Command="{Binding ToggleMonitoringCommand}"
                                Style="{StaticResource AccentActionButtonStyle}"
                                ToolTip="切换当前点位是否纳入监测"
                                Content="{Binding MonitorToggleText}" />
                    </UniformGrid>
                </Grid>
            </Border>
        </Grid>

        <Border Grid.Row="2" Padding="18" Margin="0,16,0,0" Style="{StaticResource PanelCardStyle}">
            <StackPanel>
                <TextBlock Style="{StaticResource SectionTitleTextStyle}" Text="异常缩略条" />
                <ScrollViewer Margin="0,14,0,0" HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled">
                    <ItemsControl ItemsSource="{Binding VisibleAlerts}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <StackPanel Orientation="Horizontal" />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Button Margin="0,0,12,0"
                                        Command="{Binding DataContext.SelectAlertCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                        CommandParameter="{Binding}"
                                        Style="{StaticResource AlertSelectButtonStyle}">
                                    <Grid Width="220">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="88" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>

                                        <Border Width="76"
                                                Height="48"
                                                CornerRadius="8"
                                                BorderBrush="{StaticResource SubtleBorderBrush}"
                                                BorderThickness="1"
                                                Background="{StaticResource PanelAltBrush}">
                                            <Image Stretch="UniformToFill"
                                                   Source="{Binding SnapshotPath}" />
                                        </Border>

                                        <StackPanel Grid.Column="1" Margin="12,0,0,0">
                                            <TextBlock FontWeight="SemiBold" Text="{Binding PointDisplayName}" />
                                            <TextBlock Margin="0,4,0,0" Style="{StaticResource CaptionTextStyle}" Text="{Binding IssueLabel}" />
                                            <TextBlock Margin="0,4,0,0"
                                                       MaxWidth="112"
                                                       TextWrapping="Wrap"
                                                       Style="{StaticResource MutedTextStyle}"
                                                       Text="{Binding RuntimeSummary}" />
                                            <TextBlock Margin="0,6,0,0" Style="{StaticResource MutedTextStyle}" Text="{Binding OccurredAtText, StringFormat=最近变化：{0}}" />
                                        </StackPanel>
                                    </Grid>
                                </Button>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </StackPanel>
        </Border>
    </Grid>
</Window>
