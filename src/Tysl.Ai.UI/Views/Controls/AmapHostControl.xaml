<UserControl x:Class="Tysl.Ai.UI.Views.Controls.AmapHostControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
             mc:Ignorable="d">
    <Grid>
        <Border Background="{StaticResource PanelAltBrush}"
                BorderBrush="{StaticResource SubtleBorderBrush}"
                BorderThickness="1"
                CornerRadius="18" />

        <wv2:WebView2 x:Name="Browser"
                      HorizontalAlignment="Stretch"
                      VerticalAlignment="Stretch"
                      Visibility="Collapsed" />

        <Border x:Name="HostStateOverlay"
                Background="{StaticResource PanelAltBrush}"
                BorderBrush="{StaticResource SubtleBorderBrush}"
                BorderThickness="1"
                CornerRadius="18"
                Visibility="Collapsed">
            <TextBlock x:Name="HostStateTextBlock"
                       MaxWidth="280"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"
                       Foreground="{StaticResource TextMutedBrush}"
                       TextAlignment="Center"
                       TextWrapping="Wrap" />
        </Border>
    </Grid>
</UserControl>
