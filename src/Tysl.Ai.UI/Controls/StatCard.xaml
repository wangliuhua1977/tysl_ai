<UserControl x:Class="Tysl.Ai.UI.Controls.StatCard"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             MinWidth="112">
    <Border Style="{StaticResource PanelCardStyle}"
            Padding="14,12"
            Margin="0,0,12,12"
            ToolTip="{Binding Hint, RelativeSource={RelativeSource AncestorType=UserControl}}">
        <StackPanel>
            <TextBlock Text="{Binding Title, RelativeSource={RelativeSource AncestorType=UserControl}}"
                       Style="{StaticResource CaptionTextStyle}" />
            <TextBlock Margin="0,4,0,0"
                       FontSize="20"
                       FontWeight="SemiBold"
                       Foreground="{StaticResource TextPrimaryBrush}"
                       Text="{Binding Value, RelativeSource={RelativeSource AncestorType=UserControl}}" />
        </StackPanel>
    </Border>
</UserControl>
