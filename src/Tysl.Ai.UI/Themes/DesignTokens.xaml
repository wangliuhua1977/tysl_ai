<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Color x:Key="AppBackgroundColor">#07111F</Color>
    <Color x:Key="PanelColor">#101C2D</Color>
    <Color x:Key="PanelAltColor">#0C1726</Color>
    <Color x:Key="CardColor">#162538</Color>
    <Color x:Key="CardAltColor">#1A3049</Color>
    <Color x:Key="BorderColor">#24405D</Color>
    <Color x:Key="SubtleBorderColor">#1C3350</Color>
    <Color x:Key="AccentColor">#2EA8FF</Color>
    <Color x:Key="AccentSoftColor">#173F62</Color>
    <Color x:Key="TextPrimaryColor">#F2F7FF</Color>
    <Color x:Key="TextMutedColor">#A6BED6</Color>
    <Color x:Key="TextDimColor">#6B87A3</Color>
    <Color x:Key="MapGridLineColor">#123B63</Color>
    <Color x:Key="MapGlowColor">#0D5D9A</Color>

    <Color x:Key="StatusMonitoringColor">#3AA8FF</Color>
    <Color x:Key="StatusNormalColor">#2ED19A</Color>
    <Color x:Key="StatusAlertColor">#FF9862</Color>
    <Color x:Key="StatusDispatchedColor">#FFD36D</Color>
    <Color x:Key="StatusOfflineColor">#FF6B8B</Color>

    <SolidColorBrush x:Key="AppBackgroundBrush" Color="{StaticResource AppBackgroundColor}" />
    <SolidColorBrush x:Key="PanelBrush" Color="{StaticResource PanelColor}" />
    <SolidColorBrush x:Key="PanelAltBrush" Color="{StaticResource PanelAltColor}" />
    <SolidColorBrush x:Key="CardBrush" Color="{StaticResource CardColor}" />
    <SolidColorBrush x:Key="CardAltBrush" Color="{StaticResource CardAltColor}" />
    <SolidColorBrush x:Key="BorderBrush" Color="{StaticResource BorderColor}" />
    <SolidColorBrush x:Key="SubtleBorderBrush" Color="{StaticResource SubtleBorderColor}" />
    <SolidColorBrush x:Key="AccentBrush" Color="{StaticResource AccentColor}" />
    <SolidColorBrush x:Key="AccentSoftBrush" Color="{StaticResource AccentSoftColor}" />
    <SolidColorBrush x:Key="TextPrimaryBrush" Color="{StaticResource TextPrimaryColor}" />
    <SolidColorBrush x:Key="TextMutedBrush" Color="{StaticResource TextMutedColor}" />
    <SolidColorBrush x:Key="TextDimBrush" Color="{StaticResource TextDimColor}" />
    <SolidColorBrush x:Key="MapGridLineBrush" Color="{StaticResource MapGridLineColor}" />
    <SolidColorBrush x:Key="MapGlowBrush" Color="{StaticResource MapGlowColor}" />

    <SolidColorBrush x:Key="Status.Monitoring.FillBrush" Color="#183F60" />
    <SolidColorBrush x:Key="Status.Monitoring.BorderBrush" Color="{StaticResource StatusMonitoringColor}" />
    <SolidColorBrush x:Key="Status.Monitoring.TextBrush" Color="{StaticResource StatusMonitoringColor}" />

    <SolidColorBrush x:Key="Status.Normal.FillBrush" Color="#163B35" />
    <SolidColorBrush x:Key="Status.Normal.BorderBrush" Color="{StaticResource StatusNormalColor}" />
    <SolidColorBrush x:Key="Status.Normal.TextBrush" Color="{StaticResource StatusNormalColor}" />

    <SolidColorBrush x:Key="Status.Alert.FillBrush" Color="#473124" />
    <SolidColorBrush x:Key="Status.Alert.BorderBrush" Color="{StaticResource StatusAlertColor}" />
    <SolidColorBrush x:Key="Status.Alert.TextBrush" Color="{StaticResource StatusAlertColor}" />

    <SolidColorBrush x:Key="Status.Dispatched.FillBrush" Color="#4A3D18" />
    <SolidColorBrush x:Key="Status.Dispatched.BorderBrush" Color="{StaticResource StatusDispatchedColor}" />
    <SolidColorBrush x:Key="Status.Dispatched.TextBrush" Color="{StaticResource StatusDispatchedColor}" />

    <SolidColorBrush x:Key="Status.Offline.FillBrush" Color="#4C2230" />
    <SolidColorBrush x:Key="Status.Offline.BorderBrush" Color="{StaticResource StatusOfflineColor}" />
    <SolidColorBrush x:Key="Status.Offline.TextBrush" Color="{StaticResource StatusOfflineColor}" />

    <DrawingBrush x:Key="MapGridPatternBrush"
                  TileMode="Tile"
                  Viewport="0,0,56,56"
                  ViewportUnits="Absolute"
                  Stretch="None">
        <DrawingBrush.Drawing>
            <DrawingGroup>
                <GeometryDrawing Brush="Transparent">
                    <GeometryDrawing.Pen>
                        <Pen Brush="{StaticResource MapGridLineBrush}" Thickness="0.7" />
                    </GeometryDrawing.Pen>
                    <GeometryDrawing.Geometry>
                        <GeometryGroup>
                            <LineGeometry StartPoint="0,0" EndPoint="56,0" />
                            <LineGeometry StartPoint="0,0" EndPoint="0,56" />
                        </GeometryGroup>
                    </GeometryDrawing.Geometry>
                </GeometryDrawing>
            </DrawingGroup>
        </DrawingBrush.Drawing>
    </DrawingBrush>
</ResourceDictionary>
